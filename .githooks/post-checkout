#!/bin/bash
# Back-compat shim. Real setup logic lives in scripts/init_run.sh so it can be
# run as a plain `pixi run init` (no git-hook wiring needed). This wrapper only
# exists for anyone who still does `git config core.hooksPath .githooks`.
#
# git passes 3 positional args to post-checkout; init_run.sh ignores them and
# reads only --sequencer, so forward everything through.
here="$(cd "$(dirname "$0")/.." && pwd)"
exec bash "$here/scripts/init_run.sh" "$@"
