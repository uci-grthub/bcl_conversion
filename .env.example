# Copy to .env and fill in. .env is gitignored — never commit real values.
#   cp .env.example .env
#
# The Snakefile refuses to start unless all four are set. Export them into the
# shell before invoking snakemake:
#   set -a; source .env; set +a
#   pixi run snakemake --cores 8

# Nextcloud instance the reports and FASTQ share links are published to.
NEXTCLOUD_URL=https://precision.biochem.uci.edu

# Nextcloud account that owns the share directory (config: nextcloud_dir_name).
NEXTCLOUD_USER=

# Nextcloud app password for NEXTCLOUD_USER. Generate under
# Settings > Personal > Security > Devices & sessions > Create new app password.
# Use an app password, not the account login password.
NEXTCLOUD_PASSWORD=

# App password for the account in `email_sender` (snakemake_config_project.yaml),
# used by src/send_email.py to send the order/project reports.
GMAIL_APP_PASSWORD=

# Optional. SSH target used to run `occ files:scan` on the Nextcloud host after
# uploads, so the new files appear in the web UI. Requires key-based SSH access
# and docker permission on that host. Defaults to NEXTCLOUD_USER@<host of
# NEXTCLOUD_URL>. Set to "" to skip rescans (links still work; the UI may lag).
#NEXTCLOUD_SSH_HOST=

# Optional. Overrides `flexbar_bin` from the config, e.g. to point at a local
# speedup build. Unset uses the pixi-provided flexbar on PATH.
#FLEXBAR_BIN=
